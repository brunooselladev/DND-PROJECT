generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PLAYER
  DM
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      Role     @default(PLAYER)
  createdAt DateTime @default(now())
  characters Character[]
}

model Spell {
  id          String @id @default(cuid())
  name        String
  level       Int
  school      String
  castingTime String
  range       String
  components  String
  duration    String
  description String
  source      String @default("SRD")
  preparedBy  Character[] @relation("PreparedCharacterSpells")

  @@unique([name, source])
  @@index([name])
  @@index([level])
  @@index([school])
}

model Monster {
  id              String @id @default(cuid())
  name            String
  challengeRating String
  type            String
  armorClass      Int
  hitPoints       Int
  stats           Json
  actions         Json
  source          String @default("SRD")

  @@unique([name, source])
  @@index([name])
  @@index([challengeRating])
  @@index([type])
}

model Character {
  id            String @id @default(cuid())
  name          String
  userId        String
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  class         String
  level         Int
  race          String
  background    String
  strength      Int
  dexterity     Int
  constitution  Int
  intelligence  Int
  wisdom        Int
  charisma      Int
  maxHp         Int
  currentHp     Int
  temporaryHp   Int
  armorClass    Int
  spellSlots    Json
  preparedSpells Spell[] @relation("PreparedCharacterSpells")
  conditions    Json
  inventory     Json
  notes         String
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([name])
}

model Rule {
  id       String @id @default(cuid())
  title     String
  category  String
  content   String
  source    String @default("SRD")

  @@unique([title, source])
  @@index([title])
  @@index([category])
}
