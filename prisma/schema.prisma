generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}

model Spell {
  id          String @id @default(cuid())
  name        String
  level       Int
  school      String
  castingTime String
  range       String
  components  String
  duration    String
  description String
  source      String @default("SRD")

  @@index([name])
  @@index([level])
  @@index([school])
}

model Monster {
  id              String @id @default(cuid())
  name            String
  challengeRating String
  type            String
  armorClass      Int
  hitPoints       Int
  stats           Json
  actions         Json
  source          String @default("SRD")

  @@index([name])
  @@index([challengeRating])
  @@index([type])
}

model Rule {
  id       String @id @default(cuid())
  title     String
  category  String
  content   String
  source    String @default("SRD")

  @@index([title])
  @@index([category])
}
