generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  PLAYER
  DM
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      Role     @default(PLAYER)
  createdAt DateTime @default(now())
  characters Character[]
}

model Spell {
  id          String @id @default(cuid())
  name        String
  level       Int
  school      String
  castingTime String
  range       String
  components  String
  duration    String
  description String
  source      String @default("SRD")
  preparedBy  PreparedSpell[]

  @@unique([name, source])
  @@index([name])
  @@index([level])
  @@index([school])
}

model Monster {
  id              String @id @default(cuid())
  name            String
  challengeRating String
  type            String
  armorClass      Int
  hitPoints       Int
  stats           Json
  actions         Json
  source          String @default("SRD")

  @@unique([name, source])
  @@index([name])
  @@index([challengeRating])
  @@index([type])
}

model Character {
  id            String @id @default(cuid())
  name          String
  userId        String
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  class         String
  level         Int
  race          String
  background    String
  strength      Int
  dexterity     Int
  constitution  Int
  intelligence  Int
  wisdom        Int
  charisma      Int
  maxHp         Int
  currentHp     Int
  temporaryHp   Int
  armorClass    Int
  deathSaveSuccesses Int @default(0)
  deathSaveFailures  Int @default(0)
  hitDiceTotal       Int
  hitDiceSpent       Int @default(0)
  lastLongRestAt     DateTime?

  spellSlots    SpellSlot[]
  preparedSpells PreparedSpell[]
  conditions    Json
  inventory     Json
  notes         String
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([name])
}

model PreparedSpell {
  characterId String
  spellId     String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  spell       Spell     @relation(fields: [spellId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@id([characterId, spellId])
  @@index([spellId])
}

model SpellSlot {
  characterId String
  level       Int
  max         Int
  used        Int
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@id([characterId, level])
  @@index([characterId])
  @@index([level])
}

model Rule {
  id       String @id @default(cuid())
  title     String
  category  String
  content   String
  source    String @default("SRD")

  @@unique([title, source])
  @@index([title])
  @@index([category])
}
