# PostgreSQL (required)
# Pooled connection used by the app at runtime (Supabase uses 6543/pgbouncer)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dnd_compendium?schema=public"
# Direct connection used by Prisma migrations (Supabase uses 5432)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/dnd_compendium?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="lZs7RjqQnZ6gOyUyGj0zjKk8Se2kl/olYnMGYu4xAOc="

# OAuth (GitHub)
GITHUB_ID=""
GITHUB_SECRET=""

# Optional: expose the dev credentials login form outside local development.
# Leave unset in staging/preview. Only set to "1" when you really mean it.
ALLOW_DEV_CREDENTIALS=""

# OpenAI (required for document embeddings and /chat)
# Without this, PDF uploads still work but chunks won't be embedded and chat is disabled.
OPENAI_API_KEY=""
